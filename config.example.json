{
  "port": 8919,
  "host": "0.0.0.0",
  "target_host": "api.kimi.com",
  "target_path_prefix": "/coding",
  "coding_ua": "claude-cli/2.1.44 (external, sdk-cli)",
  "auto_thinking": true,
  "thinking_budget_tokens": 512,
  "rate_limit_rpm": 30,
  "max_retries": 2,
  "request_timeout_ms": 120000,
  "retry_on_http_error": true,
  "disable_backoff_ms": [60000, 300000, 900000, 1800000, 3600000],
  "quota_disable_ms": 3600000,
  "rpm_wait_max_ms": 5000,
  "force_temperature": {},
  "models": [
    { "id": "kimi-thinking", "name": "Kimi Thinking" },
    { "id": "kimi", "name": "Kimi", "thinking": false }
  ],
  "keys": [
    {
      "key": "sk-kimi-your-key-1",
      "name": "kimi-1",
      "note": "示例备注",
      "weight": 1
    }
  ],
  "admin": {
    "enabled": true,
    "token": "change-me-to-a-random-string"
  },
  "probe_check": {
    "enabled": true,
    "path": "/coding/v1/chat/completions",
    "model": "kimi-for-coding",
    "interval_ms": 600000
  },
  "feishu": {
    "enabled": false,
    "webhook": ""
  }
}
