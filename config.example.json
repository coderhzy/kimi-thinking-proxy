  "keys": [
    {
      "key": "sk-kimi-your-key-1",
      "name": "kimi-1",
      "weight": 1
    },
    {
      "key": "sk-kimi-your-key-2",
      "name": "kimi-2",
      "weight": 1
    }
  ],
  "probe_check": {
    "enabled": true,
    "path": "/coding/v1/chat/completions",
    "model": "kimi-for-coding",
